<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="hydration_and_calorie_tracker.App"
             xmlns:local="using:hydration_and_calorie_tracker"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />

        <!-- Set properties for all buttons app-wide -->
        <StyleInclude
            Source="avares://hydration-and-calorie-tracker/Styles/ButtonStyles.axaml" />
    </Application.Styles>
</Application>