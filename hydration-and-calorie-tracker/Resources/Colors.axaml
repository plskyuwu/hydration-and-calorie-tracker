<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="BackgroundBrush">#121212</SolidColorBrush>
    <SolidColorBrush x:Key="SurfaceBrush">#1E1E1E</SolidColorBrush>
    <SolidColorBrush x:Key="SurfaceVariantBrush">#3A3A3A</SolidColorBrush>

    <!-- Text -->
    <SolidColorBrush x:Key="TextOnBackgroundBrush">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="TextOnSurfaceBrush">#E0E0E0</SolidColorBrush>
    <SolidColorBrush x:Key="TextMutedBrush">#888888</SolidColorBrush>

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrush">#5F5F5F</SolidColorBrush>
</ResourceDictionary>