<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <Border Padding="20">
            <!-- Previewer controls -->
            <StackPanel Spacing="16">
                <Button Content="Test button" />
                <Button Classes="delete" Content="Test button" />
            </StackPanel>
        </Border>
    </Design.PreviewWith>

    <Style Selector="Button">
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="Background"
                Value="{StaticResource SurfaceVariantBrush}" />
        <Setter Property="Foreground"
                Value="{StaticResource TextOnSurfaceBrush}" />
        <Setter Property="CornerRadius" Value="7" />
    </Style>

    <Style Selector="Button.delete">
        <Setter Property="Background" Value="Red" />
        <Setter Property="BorderBrush" Value="IndianRed" />
    </Style>

    <Style Selector="Button.delete:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="DarkRed" />
    </Style>
</Styles>