<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <Border Padding="20" Width="300" Height="150">
            <NumericUpDown Value="67" />
        </Border>
    </Design.PreviewWith>

    <Style Selector="NumericUpDown">
        <!-- Set a height to prevent the NumericUpDown from changing
             its height when it's empty or contains text -->
        <Setter Property="Height" Value="32" />
    </Style>
</Styles>