<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="676" d:DesignHeight="584"
             x:Class="hydration_and_calorie_tracker.Views.ItemsPageView"
             xmlns:vm="using:hydration_and_calorie_tracker.ViewModels"
             x:DataType="vm:ItemsPageViewModel">

    <Design.DataContext>
        <vm:ItemsPageViewModel />
    </Design.DataContext>

    <Border Classes="card">
        <DockPanel>

            <!-- Page title -->
            <Border Classes="pageTitle" DockPanel.Dock="Top" Margin="250 8 250 8">
                <TextBlock Classes="pageTitle"
                           Text="{Binding PageTitle}"
                           HorizontalAlignment="Center"
                           Margin="0 8 0 8" />
            </Border>

            <!-- Page content -->
            <Grid></Grid>

        </DockPanel>
    </Border>

</UserControl>